<section id="contacts" class="section contact-section">
  <div class="container two-col">
    <div>
      <p class="eyebrow">Контакты</p>
      <h2>Получить предложение по офисам</h2>
      <p>
        Оставьте свои контакты, и мы свяжемся с вами для подготовки предложения.
      </p>

      <div class="contact-cards">
        <a href="tel:+998505906059">+998 50 590 60 59</a>
        <a href="mailto:Sanjar.Saimatov@CMWP.uz">Sanjar.Saimatov@CMWP.uz</a>
        <a href="https://t.me/sanjar_saymatov_cmwp" target="_blank" rel="noopener noreferrer">
          @sanjar_saymatov_cmwp
        </a>
      </div>
    </div>

    <form 
      class="lead-form" 
      id="lead-form"
      action="https://formspree.io/f/xqevgjvo"
      method="POST"
    >
      <label>
        Имя
        <input name="name" type="text" placeholder="Ваше имя" required />
      </label>

      <label>
        Телефон
        <input name="phone" type="tel" placeholder="+998 __ ___-__-__" required />
      </label>

      <label>
        Email
        <input name="email" type="email" placeholder="name@example.com" />
      </label>

      <label>
        Комментарий
        <textarea name="message" rows="4" placeholder="Какая площадь интересует?"></textarea>
      </label>

      <label class="checkbox-row">
        <input name="privacy" type="checkbox" required />
        <span>Согласен на обработку персональных данных</span>
      </label>

      <input type="hidden" name="_subject" value="Новая заявка с сайта" />

      <button class="button button-dark" type="submit">Отправить</button>
      <p class="form-note" role="status"></p>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector('#lead-form');
  const note = document.querySelector('.form-note');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (note) {
      note.textContent = 'Отправляем заявку...';
    }

    const formData = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: {
          Accept: 'application/json'
        }
      });

      if (response.ok) {
        form.reset();

        if (note) {
          note.textContent = 'Спасибо! Заявка отправлена.';
        }
      } else {
        if (note) {
          note.textContent = 'Ошибка отправки. Попробуйте ещё раз.';
        }
      }
    } catch (error) {
      if (note) {
        note.textContent = 'Ошибка соединения. Попробуйте позже.';
      }
    }
  });
</script>