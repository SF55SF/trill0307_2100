      "image": "https://www.trilliant.uz/images/hero-bg.jpg",
      "telephone": "+998505906059",
      "email": "Sanjar.Saimatov@CMWP.uz",
      "description": "Собственник офисных помещений в бизнес-центре Trilliant предлагает готовые офисы с ремонтом и мебелью в аренду в центре Ташкента.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "улица Шахрисабз, 2",
        "addressLocality": "Ташкент",
        "addressCountry": "UZ"
      },
      "areaServed": {
        "@type": "City",
        "name": "Ташкент"
      },
      "makesOffer": [
        {
          "@type": "Offer",
