---
import '../styles/global.css';
import Seo from '../components/Seo.astro';

const {
  title = 'Бизнес центр Trilliant — аренда готовых офисов класса А в Ташкенте',
  description = 'Готовые офисы с ремонтом и мебелью в бизнес-центре Trilliant на улице Шахрисабз, 2 в Ташкенте.',
  canonical = 'https://www.trilliant.uz/',
  image = 'https://www.trilliant.uz/images/hero-bg.jpg',
} = Astro.props;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "RealEstateAgent",
  "name": "Бизнес центр Trilliant",
  "url": "https://www.trilliant.uz/",
  "image": "https://www.trilliant.uz/images/hero-bg.jpg",
  "telephone": "+998505906059",
  "email": "Sanjar.Saimatov@CMWP.uz",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "улица Шахрисабз, 2",
    "addressLocality": "Ташкент",
    "addressCountry": "UZ"
  },
  "areaServed": {
    "@type": "City",
    "name": "Ташкент"
  },
  "description": "Готовые офисы с ремонтом и мебелью в аренду в бизнес-центре Trilliant класса А в центре Ташкента."
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <Seo
      title={title}
      description={description}
      canonical={canonical}
      image={image}
    />

    <meta name="google-site-verification" content="xEHhemrNGnHxS9IjiRBJbUxS5rNS1AnUkUCBgjnx_NY" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    ></script>
  </head>

  <body>
    <slot />
  </body>
</html>